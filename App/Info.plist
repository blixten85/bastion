<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Bastion</string>
	<!-- GENERATE_INFOPLIST_FILE är NO (manuellt underhållen Info.plist),
	     så Xcode auto-injicerar ALDRIG den här nyckeln — normalt görs det
	     bara vid GENERATE_INFOPLIST_FILE: YES. Utan den kunde arkivet
	     byggas men EXPORTEN misslyckades: "Couldn't find platform family
	     for 'Bastion.app'" (tionde riktiga testflight.yml-körningen,
	     2026-07-08 — arkiveringen lyckades då för första gången, vilket
	     var precis vad som avslöjade det här, tidigare aldrig nådda,
	     steget). -->
	<key>CFBundleSupportedPlatforms</key>
	<array>
		<string>iPhoneOS</string>
	</array>
	<key>NSFaceIDUsageDescription</key>
	<string>Lås upp Bastion med Face ID i stället för att skriva ett lösenord varje gång.</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- OAuth-redirect (se OAuthProviders.swift) — samma schema måste
	     registreras hos varje leverantör som "Redirect URI". -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>se.denied.bastion.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>se.denied.bastion</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
