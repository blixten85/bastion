default_platform(:ios)

# TestFlight-uppladdning. Körs manuellt (workflow_dispatch, se
# .github/workflows/testflight.yml) — inte på varje push, eftersom varje
# körning konsumerar ett byggnummer hos Apple.
#
# Signering via `match` (readonly), INTE `-allowProvisioningUpdates` längre
# — den senare visade sig, efter åtta misslyckade riktiga CI-körningar
# (2026-07-07/08), tyst ALDRIG skapa ett distributionscertifikat på en
# engångs-CI-runner (bara utvecklingscertifikat), oavsett hur många gånger
# den kördes. Certifikat/profil är istället skapade EN gång (manuellt,
# 2026-07-08, på en riktig Mac — `security`/Keychain-operationer kräver en
# inloggad GUI-session, fungerar inte över ren SSH) och sparade krypterat
# i `blixten85/bastion-certificates` (privat repo, `MATCH_PASSWORD`-skyddat).
# CI hämtar bara — skapar aldrig nya, för att inte krocka med Apples gräns
# på antal distributionscertifikat (redan träffad en gång under felsökningen).
platform :ios do
  desc "Bygg och ladda upp till TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false,
    )

    # Nästa lediga byggnummer hos Apple, inte bara +1 på det som råkar stå i
    # projektfilen — annars kolliderar en lokal CURRENT_PROJECT_VERSION lätt
    # med ett nummer som redan laddats upp av en tidigare körning.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "se.denied.bastion",
      # Utan den här: om ingen build finns än (första körningen) returnerar
      # fastlane 1 som default, och latest + 1 gör den FÖRSTA TestFlight-
      # buildens nummer 2 istället för 1 (CodeRabbit-fynd).
      initial_build_number: 0,
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "Bastion.xcodeproj",
    )

    # Skapar en TILLFÄLLIG Keychain och pekar match mot den — utan den
    # här kan CI-runnern råka ut för samma Keychain-krångel som
    # bootstrap-körningen gjorde på den hyrda Mac:en (CodeRabbit-fynd).
    # `provider:` behövs inte för GitHub Actions — auto-detekteras via
    # GITHUB_ACTIONS-miljövariabeln.
    setup_ci if ENV["CI"]

    match(
      api_key: api_key,
      type: "appstore",
      app_identifier: "se.denied.bastion",
      team_id: ENV.fetch("APP_STORE_CONNECT_TEAM_ID"),
      git_url: "git@github.com:blixten85/bastion-certificates.git",
      readonly: true,
    )

    build_app(
      project: "Bastion.xcodeproj",
      scheme: "Bastion",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
