default_platform(:ios)

# TestFlight-uppladdning. Körs manuellt (workflow_dispatch, se
# .github/workflows/testflight.yml) — inte på varje push, eftersom varje
# körning konsumerar ett byggnummer hos Apple.
#
# Signering via `match` (readonly), INTE `-allowProvisioningUpdates` längre
# — den senare visade sig, efter åtta misslyckade riktiga CI-körningar
# (2026-07-07/08), tyst ALDRIG skapa ett distributionscertifikat på en
# engångs-CI-runner (bara utvecklingscertifikat), oavsett hur många gånger
# den kördes. Certifikat/profil är istället skapade EN gång (manuellt,
# 2026-07-08, på en riktig Mac — `security`/Keychain-operationer kräver en
# inloggad GUI-session, fungerar inte över ren SSH) och sparade krypterat
# i `blixten85/bastion-certificates` (privat repo, `MATCH_PASSWORD`-skyddat).
# CI hämtar bara — skapar aldrig nya, för att inte krocka med Apples gräns
# på antal distributionscertifikat (redan träffad en gång under felsökningen).
platform :ios do
  desc "Bygg och ladda upp till TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false,
    )

    # Nästa lediga byggnummer hos Apple, inte bara +1 på det som råkar stå i
    # projektfilen — annars kolliderar en lokal CURRENT_PROJECT_VERSION lätt
    # med ett nummer som redan laddats upp av en tidigare körning.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "se.denied.bastion",
      # Utan den här: om ingen build finns än (första körningen) returnerar
      # fastlane 1 som default, och latest + 1 gör den FÖRSTA TestFlight-
      # buildens nummer 2 istället för 1 (CodeRabbit-fynd).
      initial_build_number: 0,
    )
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "Bastion.xcodeproj",
    )

    # Skapar en TILLFÄLLIG Keychain och pekar match mot den — utan den
    # här kan CI-runnern råka ut för samma Keychain-krångel som
    # bootstrap-körningen gjorde på den hyrda Mac:en (CodeRabbit-fynd).
    # `provider:` behövs inte för GitHub Actions — auto-detekteras via
    # GITHUB_ACTIONS-miljövariabeln.
    setup_ci if ENV["CI"]

    match(
      api_key: api_key,
      type: "appstore",
      app_identifier: "se.denied.bastion",
      team_id: ENV.fetch("APP_STORE_CONNECT_TEAM_ID"),
      git_url: "git@github.com:blixten85/bastion-certificates.git",
      readonly: true,
    )

    build_app(
      project: "Bastion.xcodeproj",
      scheme: "Bastion",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )

    sentry_debug_files_upload(
      org_slug: 'anders-gh',
      project_slug: 'bastion',
      include_sources: true
    )
  end
end

# tvOS-motsvarigheten till :ios-lanen ovan — samma mönster (match readonly,
# nästa lediga byggnummer, upload_to_testflight), bara riktat mot
# Bastion-tvOS-targeten och dess EGNA bundle-ID (se.denied.bastion.tv, ett
# separat App Store Connect-app-record från iOS-appen).
#
# OBS, INTE verifierat mot en riktig körning än (samma försiktighet som
# resten av App/ — Xcode-only, kräver riktiga secrets). EN sak krävs
# fortfarande INNAN denna lane kan lyckas, inte görbart härifrån:
#   Ett App Store Connect-app-record för se.denied.bastion.tv måste finnas
#   (skapas i App Store Connect-webbportalen — App Store Connect-API:t
#   tillåter INTE att skapa app-record via `POST /v1/apps` oavsett
#   API-nyckelns roll, verifierat 2026-07-22, se ROADMAP.md). Kräver ett
#   beslut om SKU/primärt språk — samma manuella steg som iOS-appen redan
#   gick igenom.
#
# (Rättat 2026-07-22, cubic-fynd: certifikatet är INTE tvOS-specifikt.
# Samma delade "Apple Distribution"-certifikat som iOS-appen använder
# återanvänds här — bara provisioneringsprofilen, "match AppStore
# se.denied.bastion.tv", är tvOS-specifik. Båda är redan bootstrappade i
# blixten85/bastion-certificates sedan 2026-07-22; att tro att ett NYTT
# eget tvOS-distributionscertifikat behövs kan onödigt trigga
# certifikatsskapande och krocka med Apples gräns på antal
# distributionscertifikat per konto.)
platform :tvos do
  desc "Bygg och ladda upp tvOS-appen till TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false,
    )

    # `platform: "appletvos"` MÅSTE med — se.denied.bastion.tv är ett separat,
    # tvOS-app-record, och latest_testflight_build_number defaultar platform
    # till "ios". Utan detta frågar den efter iOS-builds på ett tvOS-record
    # (alltid tomt), faller tillbaka på initial_build_number: 0, och varje
    # körning väljer samma nummer 1 → duplikat-avvisat av Apple.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "se.denied.bastion.tv",
      platform: "appletvos",
      initial_build_number: 0,
    )
    # Stock increment_build_number (agvtool) stöder inte `target:` och är
    # projekt-brett — samma mönster som :ios-lanen ovan. Det spelar ingen roll
    # att detta rör iOS/macOS-targetens byggnummer i samma .xcodeproj: värdet
    # är efemärt på CI-runnern (checkas aldrig in) och varje lane hämtar sitt
    # EGNA nästa TestFlight-nummer per plattform innan bygget.
    increment_build_number(
      build_number: latest + 1,
      xcodeproj: "Bastion.xcodeproj",
    )

    setup_ci if ENV["CI"]

    match(
      api_key: api_key,
      type: "appstore",
      platform: "tvos",
      app_identifier: "se.denied.bastion.tv",
      team_id: ENV.fetch("APP_STORE_CONNECT_TEAM_ID"),
      git_url: "git@github.com:blixten85/bastion-certificates.git",
      readonly: true,
    )

    build_app(
      project: "Bastion.xcodeproj",
      scheme: "Bastion-tvOS",
      export_method: "app-store",
      # Utan denna kan build_app falla tillbaka på fel destination/SDK för
      # ett tvOS-schema (cubic/devin-fynd, andra granskningsrundan).
      destination: "generic/platform=tvOS",
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "se.denied.bastion.tv",
      app_platform: "appletvos",
      skip_waiting_for_build_processing: true,
    )

    sentry_debug_files_upload(
      org_slug: 'anders-gh',
      project_slug: 'bastion',
      include_sources: true
    )
  end
end
